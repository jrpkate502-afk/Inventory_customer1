rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /stats/{docId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitorCount'])
                    && request.resource.data.visitorCount == resource.data.visitorCount + 1;
      // Allow seeding the first visitor
      allow create: if docId == 'global' && request.resource.data.visitorCount == 1;
    }
  }
}
